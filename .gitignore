# Runtime output — logs and report files produced by scripts
Log/
Output/
*.log
*.xlsx
*.csv
*_FailedServers.txt

# Config files that hold credentials / tenant IDs (use *-config.json convention)
# Sample / template configs (*-config.sample.json, *-template.*) are NOT excluded.
*-config.json
*-config.xml

# Certificates and private keys
*.pfx
*.cer
*.key
*.pem
*.p12
*.crt

# Archives and disk images
*.zip
*.tar
*.gz
*.7z
*.iso
*.vhd
*.vmdk

# Temp, swap and backup files
*.tmp
*.old
*.bak
*.backup
*.swp
*.ps1~
*.cache
*.db
*.mdf
*.ldf

# Editor / IDE artefacts
.vscode/
.markdownlint.json
